# 🎯 SmartKubik Demo Page - Environment Variables Template
# Copia este archivo y personalízalo para cada demo

# ===== DEMO IDENTITY =====
VITE_DEMO_NAME=restaurante-casa-pepe
VITE_BUSINESS_TYPE=restaurante
VITE_INDUSTRY=food-service

# ===== BRANDING =====
VITE_BUSINESS_NAME=Casa Pepe Restaurante
VITE_BUSINESS_TAGLINE=Sabor auténtico desde 1985
VITE_BRAND_PRIMARY_COLOR=#e74c3c
VITE_BRAND_SECONDARY_COLOR=#34495e
VITE_BRAND_LOGO_URL=/assets/logo.png
VITE_BRAND_FAVICON=/assets/favicon.ico

# ===== CONTACT INFO =====
VITE_CONTACT_PHONE=+1-555-123-4567
VITE_CONTACT_EMAIL=contacto@casapepe.com
VITE_CONTACT_ADDRESS=Calle Principal 123, Ciudad
VITE_CONTACT_WHATSAPP=+15551234567
VITE_CONTACT_SOCIAL_FACEBOOK=https://facebook.com/casapepe
VITE_CONTACT_SOCIAL_INSTAGRAM=https://instagram.com/casapepe

# ===== CTA (Call-to-Action) =====
VITE_CTA_PRIMARY_TEXT=Quiero SmartKubik para mi restaurante
VITE_CTA_SECONDARY_TEXT=Ver demo en vivo
VITE_CTA_CONTACT_TEXT=Contactar ahora
VITE_CTA_PRICING_URL=https://smartkubik.com/pricing
VITE_CTA_CONTACT_URL=https://smartkubik.com/contact

# ===== SMARTKUBIK UPSELL =====
VITE_SMARTKUBIK_PITCH=Conecta esta página con SmartKubik y automatiza inventario, ventas y reportes
VITE_SMARTKUBIK_FEATURES=inventory,pos,reports,analytics,multi-branch
VITE_SHOW_SMARTKUBIK_BANNER=true
VITE_SMARTKUBIK_DISCOUNT_CODE=DEMO2024

# ===== DEMO METADATA =====
VITE_DEMO_VERSION=1.0
VITE_DEMO_CREATED_DATE=2024-03-03
VITE_DEMO_EXPIRY_DATE=2024-12-31
VITE_DEMO_TRACKING_ID=demo-restaurante-001

# ===== ANALYTICS =====
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FB_PIXEL_ID=
VITE_HOTJAR_ID=

# ===== FEATURES FLAGS =====
VITE_ENABLE_CHAT_WIDGET=true
VITE_ENABLE_BOOKING_FORM=true
VITE_ENABLE_MENU_SHOWCASE=true
VITE_ENABLE_TESTIMONIALS=true
VITE_ENABLE_GALLERY=true

# ===== SPECIAL OFFERS =====
VITE_PROMO_BANNER_TEXT=🎉 Oferta especial: 50% descuento - Cliente no finalizó compra
VITE_PROMO_BANNER_ENABLED=true
VITE_PROMO_URGENCY_TEXT=Solo esta semana
VITE_PROMO_ORIGINAL_PRICE=2500
VITE_PROMO_DISCOUNTED_PRICE=1250
VITE_PROMO_CURRENCY=USD

# ===== CONTENT =====
VITE_HERO_TITLE=Bienvenido a Casa Pepe
VITE_HERO_SUBTITLE=La mejor experiencia gastronómica de la ciudad
VITE_HERO_IMAGE=/assets/hero.jpg

# ===== INTEGRATION =====
# URL del tenant SmartKubik del cliente (cuando esté listo para upsell)
VITE_SMARTKUBIK_TENANT_SLUG=
VITE_SMARTKUBIK_API_ENDPOINT=https://api.smartkubik.com
