# ========================================
# HKA FACTORY - IMPRENTA DIGITAL VENEZUELA
# ========================================
# Configuración para integración con HKA Factory
# Proveedor autorizado SENIAT para emisión de facturas electrónicas
# Documentación: https://demoemisionv2.thefactoryhka.com.ve/swagger/index.html

# Modo del proveedor de imprenta
# Valores: mock | hka-factory | generic-http
IMPRENTA_PROVIDER_MODE=hka-factory

# ========================================
# CONFIGURACIÓN HKA FACTORY
# ========================================

# URL Base del API (cambiar según ambiente)
# Demo: https://demoemisionv2.thefactoryhka.com.ve
# Producción: https://emisionv2.thefactoryhka.com.ve
HKA_FACTORY_BASE_URL=https://demoemisionv2.thefactoryhka.com.ve

# Credenciales de acceso (solicitar a HKA Factory)
HKA_FACTORY_USUARIO=your-demo-user
HKA_FACTORY_CLAVE=your-demo-password

# Datos del emisor (tu empresa)
# RIF debe tener formato: [VEJPGC]-12345678-9
HKA_FACTORY_RIF_EMISOR=J-123456789-0
HKA_FACTORY_RAZON_SOCIAL=Mi Empresa C.A.

# Timeout en milisegundos (default: 45000 = 45 segundos)
HKA_FACTORY_TIMEOUT=45000

# ========================================
# EJEMPLOS DE CONFIGURACIÓN POR AMBIENTE
# ========================================

# DESARROLLO (con credenciales demo)
# IMPRENTA_PROVIDER_MODE=mock
# o
# IMPRENTA_PROVIDER_MODE=hka-factory
# HKA_FACTORY_BASE_URL=https://demoemisionv2.thefactoryhka.com.ve
# HKA_FACTORY_USUARIO=demo-user
# HKA_FACTORY_CLAVE=demo-pass

# PRODUCCIÓN (con credenciales reales)
# IMPRENTA_PROVIDER_MODE=hka-factory
# HKA_FACTORY_BASE_URL=https://emisionv2.thefactoryhka.com.ve
# HKA_FACTORY_USUARIO=prod-user
# HKA_FACTORY_CLAVE=secure-password
# HKA_FACTORY_RIF_EMISOR=J-987654321-0
# HKA_FACTORY_RAZON_SOCIAL=Empresa Real S.A.

# ========================================
# NOTAS IMPORTANTES
# ========================================
# 1. Token JWT tiene validez de 12 horas (se renueva automáticamente)
# 2. Todos los requests usan HTTPS + TLS 1.3
# 3. El RIF emisor debe estar registrado y autorizado en SENIAT
# 4. Cambiar a modo "mock" si HKA Factory no está disponible
# 5. Contacto soporte HKA: soporte_id_vnzla@thefactoryhka.com.ve
