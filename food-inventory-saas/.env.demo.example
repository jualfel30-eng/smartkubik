# ===================================
# HKA FACTORY DEMO ENVIRONMENT
# ===================================
# Este archivo contiene las credenciales para el ambiente DEMO de HKA Factory.
# NO usar en producción.
#
# Instrucciones:
# 1. Copiar este archivo como .env.demo
# 2. Solicitar credenciales demo a HKA Factory
# 3. Completar los valores reales
# 4. Ejecutar: npm run setup:hka-demo

# URL Base de HKA Factory Demo
HKA_FACTORY_BASE_URL=https://demoemisionv2.thefactoryhka.com.ve

# Credenciales de autenticación (solicitar a HKA Factory)
HKA_FACTORY_USUARIO=usuario_demo
HKA_FACTORY_CLAVE=clave_demo

# Datos del emisor (tu empresa)
HKA_FACTORY_RIF_EMISOR=J-123456789
HKA_FACTORY_RAZON_SOCIAL=EMPRESA DEMO SMARTKUBIK, C.A.

# Timeout para requests (ms)
HKA_FACTORY_TIMEOUT=45000

# ===================================
# MONGO DB (usar DB de pruebas)
# ===================================
MONGODB_URI=mongodb://localhost:27017/food-inventory-demo

# ===================================
# JWT (usar secret distinto de producción)
# ===================================
JWT_SECRET=demo_secret_key_not_for_production

# ===================================
# OTROS
# ===================================
NODE_ENV=demo
PORT=3001
