{
  "permissions": {
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run lint:check)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npx tsc:*)",
      "Bash(npx jest:*)",
      "Bash(npx vitest:*)",
      "Bash(npx eslint:*)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(npm run db:*)",
      "Bash(npm run seed:*)",
      "Bash(npm run clear-tenant:*)",
      "Bash(npm run setup:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(food-inventory-saas/src/**) || Edit(food-inventory-admin/src/**) || Edit(food-inventory-storefront/src/**) || Edit(restaurant-storefront/src/**)",
            "command": "node .claude/hooks/evidence-gate.js",
            "timeout": 15,
            "statusMessage": "evidence-gate: ¿investigaste antes de tocar?..."
          },
          {
            "type": "command",
            "if": "Edit(food-inventory-saas/src/modules/**/*.service.ts) || Edit(food-inventory-saas/src/modules/**/*.schema.ts) || Edit(food-inventory-saas/src/modules/**/*.controller.ts)",
            "command": "node .claude/skills/preflight-tenant-safety/scan.js",
            "timeout": 15,
            "statusMessage": "preflight-tenant-safety: escaneando patterns de bug..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(food-inventory-saas/src/**) || Write(food-inventory-admin/src/**) || Write(food-inventory-storefront/src/**) || Write(restaurant-storefront/src/**)",
            "command": "node .claude/hooks/evidence-gate.js",
            "timeout": 15,
            "statusMessage": "evidence-gate: ¿investigaste antes de tocar?..."
          },
          {
            "type": "command",
            "if": "Write(food-inventory-saas/src/modules/**/*.service.ts) || Write(food-inventory-saas/src/modules/**/*.schema.ts) || Write(food-inventory-saas/src/modules/**/*.controller.ts)",
            "command": "node .claude/skills/preflight-tenant-safety/scan.js",
            "timeout": 15,
            "statusMessage": "preflight-tenant-safety: escaneando patterns de bug..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "zsh scripts/wiki-change-detector.sh",
            "timeout": 10,
            "statusMessage": "Detectando cambios en wiki..."
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "node .claude/skills/wiki-sync/sync.js",
            "timeout": 30,
            "statusMessage": "wiki-sync: revisando módulos modificados..."
          }
        ]
      }
    ]
  }
}
